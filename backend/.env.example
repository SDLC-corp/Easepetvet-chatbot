# Server port the Express app listens on
PORT=3000

# Runtime environment: development | production | test
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# PostgreSQL connection.
# LOCAL (Docker): use the individual PG* vars below.
# DEPLOY (Render/managed): instead set a single DATABASE_URL and the app uses it
# (SSL turns on automatically for a DATABASE_URL; set PGSSL=false to disable).
# DATABASE_URL=postgresql://user:password@host:5432/easepetvet
# PGSSL=true
PGHOST=localhost
PGPORT=5433
PGUSER=easepetvet
PGPASSWORD=your_local_db_password
PGDATABASE=easepetvet

# Crawl settings (optional; defaults shown). robots.txt requests Crawl-delay: 10.
CRAWL_DELAY_MS=10000
CRAWL_TIMEOUT_MS=15000
CRAWL_USER_AGENT=EasePetVetBot/0.1

# Embedding settings. Active provider is OpenAI. The API key is NOT required for
# the backend or full-text retrieval to run; only for generating/querying
# embeddings (generate/test/vector search).
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=768
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_TIMEOUT_MS=20000
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_RETRIES=3
# Wait between embedding batches (ms) to respect provider rate limits.
EMBEDDING_BATCH_DELAY_MS=5000
# Vector search is used only when coverage >= this ratio (and no missing/stale).
EMBEDDING_MIN_COVERAGE=0.95
# Minimum cosine similarity (0-1) a vector hit must meet to be used. Gemini
# embeddings cluster high, so paraphrased questions land ~0.55-0.60; 0.55 keeps
# real questions while still rejecting gibberish (~0.50-0.53).
EMBEDDING_MIN_SCORE=0.55
# Legacy Gemini embedding provider (set EMBEDDING_PROVIDER=gemini to use):
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_DIMENSION=768
# EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_KEY=

# Chat answers. retrieval_only never calls an LLM. Any other value enables the
# hardcoded provider fallback chain: groq -> gemini -> openrouter -> ollama ->
# retrieval-only. Each provider is tried in order; a provider with no API key is
# skipped, and if one fails/rate-limits the next is used SILENTLY (no user-facing
# warning). Add the API key for whichever providers you want enabled.
CHAT_ANSWER_MODE=groq_first

# Shared generation params for all chat providers.
CHAT_MAX_COMPLETION_TOKENS=400
CHAT_TEMPERATURE=0.2
CHAT_TIMEOUT_MS=20000

# 1) Groq (primary)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# 2) Gemini (Google OpenAI-compatible endpoint; reuses GEMINI_API_KEY above)
GEMINI_CHAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_CHAT_MODEL=gemini-2.0-flash

# 3) OpenRouter (has free models, e.g. *:free)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 4) Ollama Cloud (verify the exact base URL for your account/key)
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_CHAT_MODEL=gpt-oss:20b

# Comma-separated origins allowed to call the chat API from a browser widget.
CHAT_WIDGET_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500,https://easepetvet.com,https://www.easepetvet.com

# Admin dashboard (optional). Leave token blank to keep the admin dashboard
# disabled (admin routes return "Admin dashboard is not configured.").
ADMIN_DASHBOARD_TOKEN=
# Automatic ~monthly website re-sync. Disabled by default.
ADMIN_SYNC_AUTO_ENABLED=false
ADMIN_SYNC_INTERVAL_DAYS=30
ADMIN_SYNC_RUN_HOUR=2
ADMIN_SYNC_RUN_MINUTE=0

# Recent conversation turns kept as memory (passed to retrieval + the LLM so
# context-dependent follow-ups like a one-word reply are understood). 0 disables
# memory (single-turn). Capped at 20.
CHAT_HISTORY_TURNS=8

# Per-conversation chat limits + optional in-chat email prompt cadence.
CHAT_MAX_MESSAGE_CHARS=800
CHAT_MAX_MESSAGE_WORDS=120
CHAT_CONVERSATION_MESSAGE_LIMIT=20
CHAT_LIMIT_WARNING_AT=3
CHAT_EMAIL_PROMPT_AFTER_FIRST=true
CHAT_EMAIL_PROMPT_INTERVAL=5

# Support email shown (clickable) when a visitor hits the conversation limit.
CHAT_SUPPORT_EMAIL=support@easepetvet.com

# Timezone for admin dashboard date/time display (IANA name).
ADMIN_DASHBOARD_TIMEZONE=America/Chicago
